# ============================================================
# Skripsita AI — Root environment example
# Copy to .env (root) and fill in. App-specific copies live in
# apps/api/.env and apps/web/.env.local — see README.
# ============================================================

# --- Database (PostgreSQL + pgvector) ---
# Local docker example: postgresql://postgres:postgres@localhost:5432/skripsita
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/skripsita?schema=public"

# --- AI Providers ---
# Primary model provider
OPENAI_API_KEY=""
OPENAI_CHAT_MODEL="gpt-5"
OPENAI_EMBEDDING_MODEL="text-embedding-3-large"

# Secondary / fallback model provider
GEMINI_API_KEY=""
GEMINI_CHAT_MODEL="gemini-2.5-pro"

# Which provider to use by default: "openai" | "gemini"
AI_PRIMARY_PROVIDER="openai"

# Embedding vector dimension (must match the column in Prisma schema)
EMBEDDING_DIM="3072"

# --- Supabase Storage ---
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_BUCKET="skripsita"

# If you don't have Supabase yet, set this to "local" to store files on disk.
# Options: "supabase" | "local"
STORAGE_DRIVER="local"

# --- API server ---
API_PORT="3001"
API_PREFIX="api"
CORS_ORIGIN="http://localhost:3000"

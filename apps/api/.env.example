# apps/api/.env  — copy from here and fill in.

# --- Database (Supabase Postgres + pgvector) ---
# Use the POOLED connection (Transaction mode, port 6543) for the app at runtime:
#   Supabase Dashboard -> Project Settings -> Database -> Connection string -> "Transaction"
DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# Use the DIRECT connection (Session mode, port 5432) for migrations / db push:
DIRECT_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# --- AI providers (isi minimal salah satu) ---
OPENAI_API_KEY=""
OPENAI_CHAT_MODEL="gpt-5"
# 1536-dim model is indexable by pgvector (recommended). Use text-embedding-3-large
# only with the halfvec setup in prisma/sql/init.sql.
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"
GEMINI_API_KEY=""
GEMINI_CHAT_MODEL="gemini-2.5-pro"
AI_PRIMARY_PROVIDER="openai"
EMBEDDING_DIM="1536"

# --- Storage (Supabase Storage in production) ---
# "supabase" for cloud, "local" for disk during local dev.
STORAGE_DRIVER="supabase"
SUPABASE_URL="https://<ref>.supabase.co"
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_BUCKET="skripsita"

# --- Server ---
API_PORT="3001"
API_PREFIX="api"
# In production set this to your Vercel web URL, e.g. https://skripsi-ai.vercel.app
CORS_ORIGIN="http://localhost:3000"

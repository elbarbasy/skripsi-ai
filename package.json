{
  "name": "skripsita-ai",
  "version": "1.0.0",
  "private": true,
  "description": "Skripsita AI — AI-powered thesis assistant platform",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "start": "turbo run start",
    "db:generate": "pnpm --filter @skripsita/api prisma:generate",
    "db:migrate": "pnpm --filter @skripsita/api prisma:migrate",
    "db:push": "pnpm --filter @skripsita/api prisma:push"
  },
  "devDependencies": {
    "turbo": "^2.1.3",
    "typescript": "^5.6.2",
    "prettier": "^3.3.3"
  }
}
